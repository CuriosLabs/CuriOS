{
  "curios": {
    "backup": {
      "enable": true
    },
    "bootefi": {
      "enable": true,
      "kernel": {
        "latest": true
      }
    },
    "filesystems": {
      "luks": {
        "enable": true
      },
      "minimal": {
        "enable": false
      }
    },
    "hardware": {
      "amdGpu": {
        "enable": false
      },
      "intelGpu": {
        "enable": false
      },
      "laptop": {
        "enable": false
      },
      "nvidiaGpu": {
        "enable": false
      }
    },
    "networking": {
      "enable": true
    },
    "others": {
      "enable": true,
      "openssl": {
        "enable": true
      }
    },
    "platform": {
      "amd64": {
        "enable": true
      },
      "rpi4": {
        "enable": false
      }
    },
    "services": {
      "ai": {
        "enable": false
      },
      "enable": true,
      "printing": {
        "enable": false
      },
      "sshd": {
        "enable": false
      }
    },
    "system": {
      "hostname": "CuriOS",
      "i18n": {
        "locale": "en_US.UTF-8"
      },
      "keyboard": "us",
      "pkgs": {
        "autoupgrade": {
          "enable": true
        },
        "gc": {
          "enable": true
        }
      },
      "timeZone": "Etc/GMT"
    },
    "virtualisation": {
      "docker": {
        "enable": false
      },
      "enable": false,
      "podman": {
        "enable": false
      },
      "wine": {
        "enable": false
      }
    }
  }
}
