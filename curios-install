#------------- Format disk function
format_disk() {
  set -eu
  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Formatting disk:${NC} ${SELECTED_DISK}"
  if [ $ENCRYPT_DISK -eq 1 ]; then
    echo -e "${YELLOW}Disk will be fully encrypted...${NC}"
  fi

  # Check if disk exist
  if fdisk -l "$SELECTED_DISK"; then
    SELECTED_DISK1="$SELECTED_DISK"1
    SELECTED_DISK2="$SELECTED_DISK"2
    if [[ $SELECTED_DISK =~ ^"/dev/nvme" ]]; then
      SELECTED_DISK1="$SELECTED_DISK"p1
      SELECTED_DISK2="$SELECTED_DISK"p2
    fi
  else
    echo -e "${RED}Disk ${SELECTED_DISK} not found!${NC}"
    exit 2
  fi
  swapoff -av
  #umount "$SELECTED_DISK"*
  wipefs -af "$SELECTED_DISK"

  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}UEFI partitioning...${NC}"
  parted --script "$SELECTED_DISK" mklabel gpt
  parted --script "$SELECTED_DISK" mkpart ESP fat32 1MB 1024MB
  parted --script "$SELECTED_DISK" set 1 esp on
  parted --script "$SELECTED_DISK" mkpart system 1024MB 100%

  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Filesystem formatting...${NC}"
  mkfs.fat -F 32 -n boot "$SELECTED_DISK1"

  LVM_MAPPED_DEVICE=$SELECTED_DISK2
  if [ $ENCRYPT_DISK -eq 1 ]; then
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}================================${NC}"
    echo -e "${BLUE}Creating encrypted partition...${NC}"
    DEVICE_NAME="cryptroot" # /dev/mapper/ name
    LVM_MAPPED_DEVICE="/dev/mapper/$DEVICE_NAME"
    cryptsetup -q --label="curiosystem" --type=luks2 luksFormat "$SELECTED_DISK2" <<<"${DISK_LUKS_KEY}"
    # open the encrypted partition and map it to /dev/mapper/$DEVICE_NAME
    echo -n "$DISK_LUKS_KEY" | cryptsetup luksOpen "$SELECTED_DISK2" $DEVICE_NAME -
  fi

  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Creating LVM volumes...${NC}"
  pvcreate "$LVM_MAPPED_DEVICE"
  # create a volume group inside
  vgcreate curioslvm "$LVM_MAPPED_DEVICE"
  # create the swap volume
  lvcreate --size 8G curioslvm --name swap
  # create the root volume (100% of free disk)
  lvcreate -l 100%FREE curioslvm --name root
  if [ $VERBOSE -eq 1 ]; then
    #pvdisplay "$LVM_MAPPED_DEVICE"
    #vgdisplay "$LVM_MAPPED_DEVICE"
    lvdisplay
    if [ $ENCRYPT_DISK -eq 1 ]; then
      cryptsetup status "$LVM_MAPPED_DEVICE"
    fi
  fi

  # Filesystem formatting
  mkfs.ext4 -L nixos /dev/mapper/curioslvm-root
  mkswap -L swap /dev/mapper/curioslvm-swap

  # DEBUG
  # Unmount and remove volumes:
  #umount /dev/mapper/curioslvm-home && umount /dev/mapper/curioslvm-root
  #lvremove /dev/curioslvm/home && lvremove /dev/curioslvm/root && lvremove /dev/curioslvm/swap
  #vgchange -an curioslvm
  #vgremove curioslvm
  #pvremove "$LVM_MAPPED_DEVICE"
}

#------------- CuriOS dotfiles install, see: https://github.com/CuriosLabs/curios-dotfiles
dotfiles_install() {
  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Custom dotfiles installation...${NC}"
  local SKEL_DIR="/mnt/etc/skel/"
  local HOME_DIR="/mnt/home/*/"
  mkdir -p "$SKEL_DIR"
  curios-dotfiles --lang "$SELECTED_LOCALE_CONSOLE" "$SKEL_DIR"
  for DIR in $HOME_DIR; do
    if [[ -d "$DIR" && "$DIR" != */lost+found/ ]]; then
      curios-dotfiles --lang "$SELECTED_LOCALE_CONSOLE" "$DIR"
      # TODO: Any way to predict OWNER at this stage ?
      chown -R 1000:100 "$DIR"
    fi
  done
}

if [ $CONFIRM_INSTALL -eq 1 ]; then
  clear
  INSTALL_START_TIME=$SECONDS
  if [ $VERBOSE -eq 1 ]; then
    lsblk -A -pdn -o NAME
  fi
  if [ $RPI4_INSTALL -eq 0 ]; then
    format_disk
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}================================${NC}"
    echo -e "${BLUE}Mounting system...${NC}"
    sleep 2s
    if ! mountpoint -q /mnt; then
      mount /dev/disk/by-label/nixos /mnt
    fi
    mkdir -p /mnt/boot
    if ! mountpoint -q /mnt/boot; then
      mount -o umask=077 /dev/disk/by-partlabel/ESP /mnt/boot
    fi
    if [[ $(swapon -s | wc -l) -eq 1 ]]; then
      swapon /dev/disk/by-label/swap
    fi
    mkdir -p /mnt/home
  else
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}================================${NC}"
    echo -e "${BLUE}Mounting RPI system...${NC}"
    mount /dev/disk/by-label/FIRMWARE /mnt
    # Updating RPI firmware
    BOOTFS=/mnt rpi-eeprom-update -d -a
  fi

  if [ $VERBOSE -eq 1 ]; then
    lsblk -A -lo NAME,SIZE,TYPE,MOUNTPOINTS,PARTLABEL,UUID
  fi

  if [ $RPI4_INSTALL -eq 0 ]; then
    echo -e "${GREEN}================================${NC}"
    echo -e "${GREEN}================================${NC}"
    echo -e "${BLUE}Create basic configuration...${NC}"
    nixos-generate-config --root /mnt --no-filesystems
  fi

  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Preparing configurations files...${NC}"
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/ "$CURIOS_SRC_PATH"/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/ "$CURIOS_SRC_PATH"/*.json
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/ "$CURIOS_SRC_PATH"/logo.txt
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/ "$CURIOS_SRC_PATH"/modules/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/desktop-apps/ "$CURIOS_SRC_PATH"/modules/desktop-apps/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/desktop-apps/ "$CURIOS_SRC_PATH"/modules/desktop-apps/*.png
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/desktop-apps/ "$CURIOS_SRC_PATH"/modules/desktop-apps/*.svg
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/filesystems/ "$CURIOS_SRC_PATH"/modules/filesystems/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/hardened/ "$CURIOS_SRC_PATH"/modules/hardened/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/hardware/ "$CURIOS_SRC_PATH"/modules/hardware/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/modules/platforms/ "$CURIOS_SRC_PATH"/modules/platforms/*.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/pkgs/curios-dotfiles/ "$CURIOS_SRC_PATH"/pkgs/curios-dotfiles/default.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/pkgs/curios-manager/ "$CURIOS_SRC_PATH"/pkgs/curios-manager/default.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/pkgs/curios-manager-applet/ "$CURIOS_SRC_PATH"/pkgs/curios-manager-applet/default.nix
  install -D -m 644 -t "$NIXOS_CONFIG_DIR"/pkgs/snitch/ "$CURIOS_SRC_PATH"/pkgs/snitch/default.nix

  # User settings
  sed "s/users\..*/users.${USERNAME} = {/g" -i "$NIXOS_CONFIG_DIR"/settings.nix
  sed "s/description = \".*/description = \"${FULLNAME}\";/g" -i "$NIXOS_CONFIG_DIR"/settings.nix
  sed "s#initialHashedPassword = \".*#initialHashedPassword = \"${HASHED_USER_PASSWD}\";#g" -i "$NIXOS_CONFIG_DIR"/settings.nix

  # Update modules.json with selected locale, keyboard, time zone and hostname:
  jq --arg locale "$SELECTED_LOCALE" \
    --arg kbd "$SELECTED_LOCALE_CONSOLE" \
    --arg tz "$SELECTED_TZ" \
    --arg host "$PC_HOSTNAME" \
    '.curios.system.i18n.locale = $locale | .curios.system.keyboard = $kbd | .curios.system.timeZone = $tz | .curios.system.hostname = $host' \
    "$NIXOS_CONFIG_DIR"/modules.json >/tmp/modules.json && mv /tmp/modules.json "$NIXOS_CONFIG_DIR"/modules.json
  # platform settings:
  OPTION_PLATFORM_RPI4=false
  OPTION_PLATFORM_AMD64=true
  OPTION_BOOTEFI=true
  OPTION_FS_LUKS=true
  OPTION_FS_MINI=false
  if [ $RPI4_INSTALL -eq 0 ]; then
    OPTION_PLATFORM_RPI4=false
    OPTION_PLATFORM_AMD64=true
    OPTION_BOOTEFI=true
    # filesystems settings:
    if [ $ENCRYPT_DISK -eq 1 ]; then
      OPTION_FS_LUKS=true
      OPTION_FS_MINI=false
    else
      OPTION_FS_LUKS=false
      OPTION_FS_MINI=true
    fi
  else
    OPTION_PLATFORM_RPI4=true
    OPTION_PLATFORM_AMD64=false
    OPTION_BOOTEFI=false
    OPTION_FS_LUKS=false
    OPTION_FS_MINI=false
  fi
  jq --argjson rpi4 "$OPTION_PLATFORM_RPI4" \
    --argjson amd64 "$OPTION_PLATFORM_AMD64" \
    --argjson efi "$OPTION_BOOTEFI" \
    --argjson luks "$OPTION_FS_LUKS" \
    --argjson mini "$OPTION_FS_MINI" \
    '.curios.platform.amd64.enable = $amd64 | .curios.platform.rpi4.enable = $rpi4 | .curios.filesystems.luks.enable = $luks | .curios.filesystems.minimal.enable = $mini' \
    "$NIXOS_CONFIG_DIR"/modules.json >/tmp/modules.json && mv /tmp/modules.json "$NIXOS_CONFIG_DIR"/modules.json
  # GPU settings:
  OPTION_GPU_AMD=false
  OPTION_GPU_NVIDIA=false
  OPTION_GPU_INTEL=false
  OPTION_KERNEL_LATEST=true
  if [[ "$GPU_INSTALL" -eq 1 && "$GPU_VENDOR_DETECTED" == "AMD" ]]; then
    echo "Enabling AMD GPU..."
    OPTION_GPU_AMD=true
  elif [[ "$GPU_INSTALL" -eq 1 && "$GPU_VENDOR_DETECTED" == "Intel" ]]; then
    echo "Enabling Intel GPU..."
    OPTION_GPU_INTEL=true
  elif [[ "$GPU_INSTALL" -eq 1 && "$GPU_VENDOR_DETECTED" == "Nvidia" ]]; then
    echo "Enabling Nvidia GPU..."
    OPTION_GPU_NVIDIA=true
    # Switch to LTS kernel by default for Nvidia GPU
    OPTION_KERNEL_LATEST=false
  fi
  jq --argjson gpuAmd "$OPTION_GPU_AMD" \
    --argjson gpuIntel "$OPTION_GPU_INTEL" \
    --argjson gpuNvidia "$OPTION_GPU_NVIDIA" \
    --argjson kernelLatest "$OPTION_KERNEL_LATEST" \
    '.curios.hardware.amdGpu.enable = $gpuAmd | .curios.hardware.intelGpu.enable = $gpuIntel | .curios.hardware.nvidiaGpu.enable = $gpuNvidia | .curios.bootefi.kernel.latest = $kernelLatest' \
    "$NIXOS_CONFIG_DIR"/modules.json >/tmp/modules.json && mv /tmp/modules.json "$NIXOS_CONFIG_DIR"/modules.json

  echo -e "${GREEN}================================${NC}"
  echo -e "${GREEN}================================${NC}"
  echo -e "${BLUE}Launching NixOS installer...${NC}"
  # Configure Nix channel
  NIX_CHANNEL_URL=$(grep -oP -m 1 'channel\s*=\s*"\K[^"]+' "$NIXOS_CONFIG_DIR"/configuration.nix)
  if [ -z "$NIX_CHANNEL_URL" ]; then
    echo -e "${RED}Nix channel not found in configuration.nix!${NC}"
    exit 1
  fi
  echo "Adding channel: $NIX_CHANNEL_URL"
  nix-channel --add "$NIX_CHANNEL_URL" nixos
  nix-channel --update
  if [ $RPI4_INSTALL -eq 0 ]; then
    nixos-install --cores 0 --no-root-passwd
  else
    nixos-rebuild boot
  fi

  if [ $DO_DOTFILES_INSTALL -eq 1 ]; then
    dotfiles_install
  fi

  INSTALL_END_TIME=$SECONDS
  DURATION=$((INSTALL_END_TIME - INSTALL_START_TIME))
  MINUTES=$((DURATION / 60))
  SECONDS_REM=$((DURATION % 60))
  TIME_RESULT=$(printf "%02d:%02d" $MINUTES $SECONDS_REM)

  echo -e "${GREEN}Done...${NC}"
  gum format "# Success" "CuriOS was successfully installed in ${TIME_RESULT}!" "Remember to remove USB installer!"
  if gum confirm "Reboot now?"; then
    reboot now
  fi
fi
