#------------- Choose timezone
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
set_tz() {
  echo "Choose your timezone:"
  local DEFAULT_TZ="${LANG_TO_TZ_DEFAULT[$LANG_CHOICE]}"
  SELECTED_TZ=$(gum choose --selected="$DEFAULT_TZ" "${LOCALES_TZ[@]}")
  exit_status=$?

  if [ $exit_status -ne 0 ]; then
    choose_lang
    return
  fi

  if [ -z "$SELECTED_TZ" ]; then
    choose_lang
    return
  fi

  set_hostname
}

#------------- Choose machine name
set_hostname() {
  echo "Enter this machine hostname:"
  result=$(gum input --placeholder "Hostname" --value "$PC_HOSTNAME")
  exit_status=$?

  if [ $exit_status -ne 0 ]; then
    set_tz
    return
  fi

  PC_HOSTNAME=$result
  if ! [[ $PC_HOSTNAME =~ ^[[:alnum:].]+$ ]]; then
    display_error "Invalid hostname! It could only contain alphanumerical or '.' characters."
    set_hostname
  else
    set_username
  fi
}

#------------- Choose username
set_username() {
  echo "Enter your username (id):"
  result=$(gum input --placeholder "Username" --value "$USERNAME")
  exit_status=$?

  if [ $exit_status -ne 0 ]; then
    set_hostname
    return
  fi

  USERNAME=$result
  if [ -z "$USERNAME" ]; then
    display_error "username cannot be empty."
    set_username
  elif ! [[ $USERNAME =~ ^[[:alnum:]]+$ ]]; then
    display_error "Invalid username! It could only contain alphanumerical characters."
    set_username
  else
    set_fullname
  fi
}

#------------- Choose user full name
set_fullname() {
  echo "Enter your full name:"
  result=$(gum input --placeholder "Full Name" --value "$FULLNAME")
  exit_status=$?

  if [ $exit_status -ne 0 ]; then
    set_username
    return
  fi

  FULLNAME=$result
  if [ -z "$FULLNAME" ]; then
    FULLNAME="Dwight K. Schrute"
  fi
  if ! [[ $FULLNAME =~ ^[[:alnum:][:space:].]+$ ]]; then
    display_error "Invalid full name! it could only contain alphanumerical, '.' or space characters."
    set_fullname
  else
    set_user_passwd
  fi
}

#------------- Set user password
set_user_passwd() {
  echo "Enter your password (6 characters minimum):"
  password=$(gum input --password --placeholder "Password")
  if [ $? -ne 0 ]; then
    set_fullname
    return
  fi

  echo "Confirm your password:"
  confirm=$(gum input --password --placeholder "Confirm Password")
  if [ $? -ne 0 ]; then
    set_user_passwd
    return
  fi

  # Compare and check password length
  if [ "${#password}" -le 5 ]; then
    display_error "Password is too short! It should be at least 6 characters long."
    set_user_passwd
  elif [[ "$password" != "$confirm" ]]; then
    display_error "Password mismatch! Password and confirmation are different."
    set_user_passwd
  else
    HASHED_USER_PASSWD=$(mkpasswd -m yescrypt "$password")
    if [ $RPI4_INSTALL -eq 1 ]; then
      confirm_install
    else
      choose_disk
    fi
  fi
}

#------------- Choose install disk
choose_disk() {
  DEVICES_LIST=()
  for device in $(lsblk -A -pdn -o NAME); do
    DISK_SIZE=$(lsblk -dn -o SIZE "$device")
    DISK_MODEL=$(lsblk -dn -o MODEL "$device")
    DEVICES_LIST+=("$device ($DISK_SIZE - $DISK_MODEL)")
  done

  echo "Choose which disk to install CuriOS on:"
  selection=$(gum choose "${DEVICES_LIST[@]}")
  exit_status=$?

  if [ $exit_status -ne 0 ]; then
    set_user_passwd
    return
  fi

  SELECTED_DISK=$(echo "$selection" | cut -d' ' -f1)
  choose_disk_encryption
}

choose_disk_encryption() {
  if gum confirm "Should your disk be fully encrypted (highly recommended)?"; then
    echo "Enter your passphrase for the full disk encryption (8 characters minimum):"
    passphrase=$(gum input --password --placeholder "Passphrase")
    if [ $? -ne 0 ]; then
      choose_disk
      return
    fi

    echo "Confirm your passphrase:"
    confirm=$(gum input --password --placeholder "Confirm Passphrase")
    if [ $? -ne 0 ]; then
      choose_disk_encryption
      return
    fi

    if [ ${#passphrase} -le 7 ]; then
      display_error "Passphrase is too short! It should be at least 8 characters long."
      choose_disk_encryption
    elif ! [[ $passphrase =~ ^[[:alnum:]]+$ ]]; then
      display_error "Invalid passphrase! it could only contain alphanumerical characters."
      choose_disk_encryption
    elif [[ "$passphrase" != "$confirm" ]]; then
      display_error "Passphrase mismatch! Passphrase and confirmation are different."
      choose_disk_encryption
    else
      ENCRYPT_DISK=1
      DISK_LUKS_KEY=$passphrase
      hardware_detection_gpu
    fi
  else
    ENCRYPT_DISK=0
    hardware_detection_gpu
  fi
}

hardware_detection_gpu() {
  NB_GPU=$(lspci | grep -ci "vga")
  if [ $VERBOSE -eq 1 ]; then
    echo -e "${GREY}${NB_GPU}${NC} GPU found."
  fi
  if [ "$NB_GPU" -ge 1 ]; then
    GPU=$(lspci -nn | grep -i "vga")
    if echo "$GPU" | grep -qi "amd"; then
      GPU_VENDOR_DETECTED="AMD"
    elif echo "$GPU" | grep -qi "intel"; then
      GPU_VENDOR_DETECTED="Intel"
    elif echo "$GPU" | grep -qi "nvidia"; then
      GPU_VENDOR_DETECTED="Nvidia"
    fi
    if [[ -n $GPU_VENDOR_DETECTED ]]; then
      if gum confirm "GPU detected: $GPU_VENDOR_DETECTED. Would you like to install the hardware pilot (recommended)? It may imply the installation of unfree packages."; then
        GPU_INSTALL=1
      else
        GPU_INSTALL=0
      fi
    fi
  fi
  confirm_install
}

confirm_install() {
  if gum confirm "Proceed with installation? Your hard drive disk will be formatted and all data erased."; then
    CONFIRM_INSTALL=1
  else
    echo "Program terminated without any installation." >&2
  fi
}

