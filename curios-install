#!/usr/bin/env bash

# Gum driven CuriOS install script as NixOS package.
# Meant to be run during an NixOS ISO installation.
# !IMPORTANT! Run this script as sudo
# It will create 3 partitions for '/boot', '/' and a 8Go swap
# If disk encryption is choosed, the encrypted LUKS partition will contain LVM
# partitions for '/' and a 8Go swap.
#
# Dependencies: gum, parted, git, mkpasswd.
# Test it with:
# nix-shell shell.nix

