  exit 1
fi

#------------- Check dependencies
available() { command -v "$1" >/dev/null; }

if ! available git; then
  echo -e "${RED}git command not found!${NC}"
  exit 2
fi
if ! available mkpasswd; then
  echo -e "${RED}mkpasswd command not found!${NC}"
  exit 2
fi
if ! available gum; then
  echo -e "${RED}gum command not found!${NC}"
  exit 2
fi
if ! available jq; then
  echo -e "${RED}jq command not found!${NC}"
  exit 2
fi
if [ $RPI4_INSTALL -eq 0 ]; then
  if ! available parted; then
    echo -e "${RED}parted command not found!${NC}"
    exit 2
  fi
  if ! available cryptsetup; then
    echo -e "${RED}cryptsetup command not found!${NC}"
    exit 2
  fi
  if ! available mkfs; then
    echo -e "${RED}mkfs command not found!${NC}"
    exit 2
  fi
else
  if ! available rpi-eeprom-update; then
    echo -e "${RED}rpi-eeprom-update command not found!${NC}"
    exit 2
  fi
fi

#------------- Check internet connectivity
